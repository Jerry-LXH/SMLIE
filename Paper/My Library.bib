@article{chenNearInfraredSpontaneouslyBlinking2024,
  title = {Near-{{Infrared Spontaneously Blinking Fluorophores}} for {{Live Cell Super-Resolution Imaging}} with {{Minimized Phototoxicity}}},
  author = {Chen, Song and Wang, Jing and Guan, Daoming and Tan, Baojin and Zhai, Tianli and Yang, Lu and Han, Yuheng and Liu, Yi and Liu, Qian and Zhang, Yunxiang},
