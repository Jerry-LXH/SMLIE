@article{gaoExpansionStimulatedEmission2018,
  title = {Expansion {{Stimulated Emission Depletion Microscopy}} ({{ExSTED}})},
  author = {Gao, Mengfei and Maraspini, Riccardo and Beutel, Oliver and Zehtabian, Amin and Eickholt, Britta and Honigmann, Alf and Ewers, Helge},
  year = 2018,
  month = may,
  journal = {ACS Nano},
  volume = {12},
  number = {5},
  pages = {4178--4185},
  publisher = {American Chemical Society},
  issn = {1936-0851},
  doi = {10.1021/acsnano.8b00776},
  urldate = {2024-09-02},
  abstract = {Stimulated emission depletion (STED) microscopy is routinely used to resolve the ultrastructure of cells with a {$\sim$}10-fold higher resolution compared to diffraction limited imaging. While STED microscopy is based on preparing the excited state of fluorescent probes with light, the recently developed expansion microscopy (ExM) provides subdiffraction resolution by physically enlarging the sample before microscopy. The expansion of the fixed cells by cross-linking and swelling of hydrogels easily enlarges the sample {$\sim$}4-fold and hence increases the effective optical resolution by this factor. To overcome the current limits of these complementary approaches, we combined ExM with STED (ExSTED) and demonstrated an increase in resolution of up to 30-fold compared to conventional microscopy ({$<$}10 nm lateral and {$\sim$}50 nm isotropic). While the increase in resolution is straightforward, we found that high-fidelity labeling via multi-epitopes is required to obtain emitter densities that allow ultrastructural details with ExSTED to be resolved. Our work provides a robust template for super-resolution microscopy of entire cells in the ten nanometer range.},
  lccn = {1},
  keywords = {Done,Key,Useful},
  annotation = {154 citations (Crossref/DOI) [2024-09-08]\\
154 citations (Crossref/DOI) [2024-09-08]},
  file = {/Users/jerryling/Zotero/storage/87XBIBTB/nn8b00776_si_001.pdf;/Users/jerryling/Zotero/storage/YJFQQ3TH/Gao et al. - 2018 - Expansion Stimulated Emission Depletion Microscopy.pdf}
}

@article{gaoHighlyHomogeneousPolymer2021,
