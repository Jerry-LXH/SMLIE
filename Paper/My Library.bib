  file = {/Users/jerryling/Zotero/storage/P3ZFD9JU/41467_2024_55267_MOESM1_ESM.pdf;/Users/jerryling/Zotero/storage/SI459GBA/Guo et al. - 2025 - Deep learning-based aberration compensation improves contrast and resolution in fluorescence microsc.pdf}
