229 citations (Crossref/DOI) [2024-12-05]},
  file = {/Users/jerryling/Zotero/storage/8VDR5A2F/41592_2020_853_MOESM1_ESM.pdf;/Users/jerryling/Zotero/storage/W4Z3FC8M/Nehme et al. - 2020 - DeepSTORM3D dense 3D localization microscopy and PSF design by deep learning.pdf}
}

