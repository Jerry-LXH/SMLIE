  doi = {10.1083/jcb.202502035},
  urldate = {2026-04-01},
  abstract = {Landscape expansion microscopy (land-ExM) is a light microscopy technique that visualizes both the lipid and protein ultrastructural context of cells. Achieving this level of detail requires both superresolution and a high signal-to-noise ratio. Although expansion microscopy (ExM) provides superresolution, obtaining high signal-to-noise images of both proteins and lipids remains challenging. land-ExM overcomes this limitation by using self-retention trifunctional anchors to significantly enhance protein and lipid signals in expanded samples. This improvement enables the accurate visualization of diverse membrane organelles and phase separations, as well as the 3D visualization of their contact sites. As a demonstration, we revealed triple-organellar contact sites among the stress granule, the nuclear tunnel, and the nucleolus. Overall, land-ExM offers a high-contrast superresolution platform that advances our understanding of how cells spatially coordinate interactions between membrane organelles and phase separations.},
