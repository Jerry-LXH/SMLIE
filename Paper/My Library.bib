15 citations (Crossref/DOI) [2025-02-28]},
  file = {/Users/jerryling/Zotero/storage/4GWCSFQ3/Liu et al. - 2024 - Universal inverse modeling of point spread functions for SMLM localization and microscope characteri.pdf}
}

@article{liuUpconversionLuminescenceImaging2013,
  title = {Upconversion Luminescence Imaging of Cells and Small Animals},
