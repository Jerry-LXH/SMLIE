  doi = {10.1016/j.bpj.2014.12.016},
  urldate = {2026-03-05},
  abstract = {{$<$}h2{$>$}Abstract{$<$}/h2{$><$}p{$>$}The ability to measure the properties of proteins at the single-molecule level offers an unparalleled glimpse into biological systems at the molecular scale. The interpretation of single-molecule time series has often been rooted in statistical mechanics and the theory of Markov processes. While existing analysis methods have been useful, they are not without significant limitations including problems of model selection and parameter nonidentifiability. To address these challenges, we introduce the use of nonparametric Bayesian inference for the analysis of single-molecule time series. These methods provide a flexible way to extract structure from data instead of assuming models beforehand. We demonstrate these methods with applications to several diverse settings in single-molecule biophysics. This approach provides a well-constrained and rigorously grounded method for determining the number of biophysical states underlying single-molecule data.{$<$}/p{$>$}},
  langid = {english},
  pmid = {25650922},
  file = {/Users/jerryling/Zotero/storage/I4UYRGY7/Hines et al. - 2015 - Analyzing Single-Molecule Time Series via Nonparametric Bayesian Inference.pdf}
}

