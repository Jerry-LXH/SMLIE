  doi = {10.2139/ssrn.5183728},
  urldate = {2025-07-12},
  abstract = {Red fluorescent carbon dots (R-CDs) have been constructed for a novel ``turn-on'' fluorescent probe to detect Fe3+. R-CDs with 70 \% yield was synthesized by hydrothermal method using erythromycin and L-isoleucine as raw materials for the first time. The prepared R-CDs have rich functional groups, good water solubility, low cytotoxicity, high fluorescence stability, and good biocompatibility. Surprisingly, R-CDs showed significant fluorescence enhancement after the introduction of Fe3+ based on the aggregation-induced emission (AIE) enhancement mechanism. The linear range of Fe3+ detected by R-CDs is 2.1 \textasciitilde{} 37.5 \textmu M, and the detection limit is 0.17 \textmu M. This method has also been successfully applied to the precise analysis of actual samples. In addition, R-CDs can also be used for multi-color cell imaging and intracellular Fe3+ sensing. It is revealed that the obtained R-CDs have great application potential in sensing and biomedicine fields.},
  archiveprefix = {Social Science Research Network},
  langid = {english},
  keywords = {/unread,aggregation-induced,Carbon dots,Fe3+,Imaging,red,sensing},
  file = {/Users/jerryling/Zotero/storage/AL22LF4R/Wen et al. - 2025 - High-Yield Red Fluorescent Carbon Dots for Turn-On Detection of Fe3+ and Multicolor Cell Imaging.pdf}
}

@article{whiteDiffusionCrosslinkedAcrylamide1961,
  title = {Diffusion in a Crosslinked Acrylamide Polymer Gel},
  author = {White, Malcolm L. and Dorion, George H.},
