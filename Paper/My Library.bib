  author = {{Mu{\~n}oz-Gil}, Gorka and Volpe, Giovanni and {Garcia-March}, Miguel Angel and Aghion, Erez and Argun, Aykut and Hong, Chang Beom and Bland, Tom and Bo, Stefano and Conejero, J. Alberto and Firbas, Nicol{\'a}s and {Garibo i Orts}, {\`O}scar and Gentili, Alessia and Huang, Zihan and Jeon, Jae-Hyung and Kabbech, H{\'e}l{\`e}ne and Kim, Yeongjin and Kowalek, Patrycja and Krapf, Diego and {Loch-Olszewska}, Hanna and Lomholt, Michael A. and Masson, Jean-Baptiste and Meyer, Philipp G. and Park, Seongyu and Requena, Borja and Smal, Ihor and Song, Taegeun and Szwabi{\'n}ski, Janusz and Thapa, Samudrajit and Verdier, Hippolyte and Volpe, Giorgio and Widera, Artur and Lewenstein, Maciej and Metzler, Ralf and Manzo, Carlo},
