@article{liuSingleUpconversionNanoparticle2018,
  title = {Single Upconversion Nanoparticle Imaging at Sub-10 {{W}} Cm-2 Irradiance},
  author = {Liu, Qian and Zhang, Yunxiang and Peng, Chunte Sam and Yang, Tianshe and Joubert, Lydia-Marie and Chu, Steven},
  year = 2018,
  month = sep,
  journal = {Nature Photonics},
