@article{yuTripletsElectricallyTurn2025,
  title = {Triplets Electrically Turn on Insulating Lanthanide-Doped Nanoparticles},
  author = {Yu, Zhongzheng and Deng, Yunzhou and Ye, Junzhi and {van Turnhout}, Lars and Liu, Tianjun and Tew, Alasdair and Arul, Rakesh and Dowland, Simon and Sun, Yuqi and Li, Xinjuan and Dai, Linjie and Lu, Yang and Ducati, Caterina and Baumberg, Jeremy J. and Friend, Richard H. and Hoye, Robert L. Z. and Rao, Akshay},
  year = 2025,
