  author = {Yanagawa, Masataka and Hiroshima, Michio and Togashi, Yuichi and Abe, Mitsuhiro and Yamashita, Takahiro and Shichida, Yoshinori and Murata, Masayuki and Ueda, Masahiro and Sako, Yasushi},
