@article{wangSingleshot20foldExpansion2024,
  title = {Single-Shot 20-Fold Expansion Microscopy},
  author = {Wang, Shiwei and Shin, Tay Won and Yoder, Harley B. and McMillan, Ryan B. and Su, Hanquan and Liu, Yixi and Zhang, Chi and Leung, Kylie S. and Yin, Peng and Kiessling, Laura L. and Boyden, Edward S.},
  year = 2024,
  month = nov,
  journal = {Nature Methods},
  volume = {21},
  number = {11},
  pages = {2128--2134},
  publisher = {Nature Publishing Group},
  issn = {1548-7105},
  doi = {10.1038/s41592-024-02454-9},
  urldate = {2024-11-22},
  abstract = {Expansion microscopy (ExM) is in increasingly widespread use throughout biology because its isotropic physical magnification enables nanoimaging on conventional microscopes. To date, ExM methods either expand specimens to a limited range (\textasciitilde 4--10\texttimes{} linearly) or achieve larger expansion factors through iterating the expansion process a second time (\textasciitilde 15--20\texttimes{} linearly). Here, we present an ExM protocol that achieves \textasciitilde 20\texttimes{} expansion (yielding {$<$}20-nm resolution on a conventional microscope) in a single expansion step, achieving the performance of iterative expansion with the simplicity of a single-shot protocol. This protocol, which we call 20ExM, supports postexpansion staining for brain tissue, which can facilitate biomolecular labeling. 20ExM may find utility in many areas of biological investigation requiring high-resolution imaging.},
  copyright = {2024 The Author(s)},
  langid = {english},
  lccn = {1},
  keywords = {/unread,Biological techniques,Biotechnology,Key,Super-resolution microscopy},
  annotation = {0 citations (Crossref/DOI) [2024-11-22]},
  file = {/Users/jerryling/Zotero/storage/H3P9UADI/Wang et al. - 2024 - Single-shot 20-fold expansion microscopy.pdf}
}

@article{wangUseDeepLearning2024,
