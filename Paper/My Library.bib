@article{zhuangLandscapeExpansionMicroscopy2026,
  title = {Landscape Expansion Microscopy Reveals Interactions between Membrane and Phase-Separated Organelles},
  author = {Zhuang, Yinyin and Zhang, Zhao and Dai, Zhipeng and Shi, Xiaoyu},
