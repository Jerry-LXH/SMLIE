@article{williamsonMachineLearningCluster2020,
  title = {Machine Learning for Cluster Analysis of Localization Microscopy Data},
  author = {Williamson, David J. and Burn, Garth L. and Simoncelli, Sabrina and Griffi{\'e}, Juliette and Peters, Ruby and Davis, Daniel M. and Owen, Dylan M.},
  year = 2020,
  month = mar,
  journal = {Nature Communications},
  volume = {11},
  number = {1},
  pages = {1493},
  publisher = {Nature Publishing Group},
  issn = {2041-1723},
  doi = {10.1038/s41467-020-15293-x},
  urldate = {2024-09-19},
  abstract = {Quantifying the extent to which points are clustered in single-molecule localization microscopy data is vital to understanding the spatial relationships between molecules in the underlying sample. Many existing computational approaches are limited in their ability to process large-scale data sets, to deal effectively with sample heterogeneity, or require subjective user-defined analysis parameters. Here, we develop a supervised machine-learning approach to cluster analysis which is fast and accurate. Trained on a variety of simulated clustered data, the neural network can classify millions of points from a typical single-molecule localization microscopy data set, with the potential to include additional classifiers to describe different subtypes of clusters. The output can be further refined for the measurement of cluster area, shape, and point-density. We demonstrate this approach on simulated data and experimental data of the kinase Csk and the adaptor PAG in primary human T cell immunological synapses.},
  copyright = {2020 The Author(s)},
  langid = {english},
  lccn = {1},
  keywords = {/unread,Fluorescence imaging,Software},
