  file = {/Users/jerryling/Zotero/storage/329R65MZ/Becker et al. - 2004 - Fluorescence lifetime imaging by time-correlated single-photon counting.pdf;/Users/jerryling/Zotero/storage/I9VPD7WI/jemt.html}
