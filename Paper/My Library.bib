@article{parkLabelfreeAdaptiveOptics2023,
  title = {Label-Free Adaptive Optics Single-Molecule Localization Microscopy for Whole Zebrafish},
  author = {Park, Sanghyeon and Jo, Yonghyeon and Kang, Minsu and Hong, Jin Hee and Ko, Sangyoon and Kim, Suhyun and Park, Sangjun and Park, Hae Chul and Shim, Sang-Hee and Choi, Wonshik},
  year = 2023,
  month = jul,
  journal = {Nature Communications},
  volume = {14},
  number = {1},
  pages = {4185},
  publisher = {Nature Publishing Group},
  issn = {2041-1723},
  doi = {10.1038/s41467-023-39896-2},
  urldate = {2025-02-23},
  abstract = {Specimen-induced aberration has been a major factor limiting the imaging depth of single-molecule localization microscopy (SMLM). Here, we report the application of label-free wavefront sensing adaptive optics to SMLM for deep-tissue super-resolution imaging. The proposed system measures complex tissue aberrations from intrinsic reflectance rather than fluorescence emission and physically corrects the wavefront distortion more than three-fold stronger than the previous limit. This enables us to resolve sub-diffraction morphologies of cilia and oligodendrocytes in whole zebrafish as well as dendritic spines in thick mouse brain tissues at the depth of up to 102\,{$\mu$}m with localization number enhancement by up to 37 times and localization precision comparable to aberration-free samples. The proposed approach can expand the application range of SMLM to whole zebrafish that cause the loss of localization number owing to severe tissue aberrations.},
  copyright = {2023 The Author(s)},
  langid = {english},
  lccn = {1},
  keywords = {/unread,Interference microscopy,Super-resolution microscopy},
