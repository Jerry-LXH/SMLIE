@article{zhouUltrafastUpconversionSuperfluorescence2024,
  title = {Ultrafast Upconversion Superfluorescence with a Sub-2.5 Ns Lifetime at Room Temperature},
  author = {Zhou, Mengwei and Huang, Ping and Shang, Xiaoying and Zhang, Ruihuan and Zhang, Wen and Shao, Zhiqing and Zhang, Shuo and Zheng, Wei and Chen, Xueyuan},
