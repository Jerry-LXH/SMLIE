@article{zelgerThreedimensionalLocalizationMicroscopy2018,
  title = {Three-Dimensional Localization Microscopy Using Deep Learning},
  author = {Zelger, P. and Kaser, K. and Rossboth, B. and Velas, L. and Sch{\"u}tz, G. J. and Jesacher, A.},
