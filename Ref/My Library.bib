  author = {Basak, Samrat and Chizhik, Alexey and Gallea, Jos{\'e} Ignacio and Gligonov, Ivan and Gregor, Ingo and Nevskyi, Oleksii and Radmacher, Niels and Tsukanov, Roman and Enderlein, J{\"o}rg},
