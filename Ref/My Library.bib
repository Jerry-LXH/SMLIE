}

@article{zhaoSquaraineDyesExhibit2024,
  title = {Squaraine {{Dyes Exhibit Spontaneous Fluorescence Blinking That Enables Live-Cell Nanoscopy}}},
  author = {Zhao, Bingjie and Guan, Daoming and Liu, Jinyang and Zhang, Xuebo and Xiao, Shuzhang and Zhang, Yunxiang and Smith, Bradley D. and Liu, Qian},
  year = {2024},
