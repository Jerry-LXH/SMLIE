}

@article{liffnerAtlasPlasmodiumFalciparum2023,
  title = {Atlas of {{Plasmodium}} Falciparum Intraerythrocytic Development Using Expansion Microscopy},
  author = {Liffner, Benjamin and Cepeda Diaz, Ana Karla and Blauwkamp, James and Anaguano, David and Frolich, Sonja and Muralidharan, Vasant and Wilson, Danny W and Dvorin, Jeffrey D and Absalon, Sabrina},
  editor = {Silvie, Olivier and {Soldati-Favre}, Dominique},
  year = {2023},
  month = dec,
  journal = {eLife},
  volume = {12},
  pages = {RP88088},
  publisher = {eLife Sciences Publications, Ltd},
  issn = {2050-084X},
  doi = {10.7554/eLife.88088},
  urldate = {2024-09-02},
  abstract = {Apicomplexan parasites exhibit tremendous diversity in much of their fundamental cell biology, but study of these organisms using light microscopy is often hindered by their small size. Ultrastructural expansion microscopy (U-ExM) is a microscopy preparation method that physically expands the sample by {\textasciitilde}4.5{\texttimes}. Here, we apply U-ExM to the human malaria parasite Plasmodium falciparum during the asexual blood stage of its lifecycle to understand how this parasite is organized in three dimensions. Using a combination of dye-conjugated reagents and immunostaining, we have cataloged 13 different P. falciparum structures or organelles across the intraerythrocytic development of this parasite and made multiple observations about fundamental parasite cell biology. We describe that the outer centriolar plaque and its associated proteins anchor the nucleus to the parasite plasma membrane during mitosis. Furthermore, the rhoptries, Golgi, basal complex, and inner membrane complex, which form around this anchoring site while nuclei are still dividing, are concurrently segregated and maintain an association to the outer centriolar plaque until the start of segmentation. We also show that the mitochondrion and apicoplast undergo sequential fission events while maintaining an association with the outer centriolar plaque during cytokinesis. Collectively, this study represents the most detailed ultrastructural analysis of P. falciparum during its intraerythrocytic development to date and sheds light on multiple poorly understood aspects of its organelle biogenesis and fundamental cell biology.},
  lccn = {1},
  keywords = {cytokinesis,expansion microscopy,malaria,MTOC,Plasmodium},
  annotation = {8 citations (Crossref/DOI) [2024-09-08]\\
8 citations (Crossref/DOI) [2024-09-08]},
  file = {/Users/jerryling/Zotero/storage/PDHB6EEY/Liffner et al. - 2023 - Atlas of Plasmodium falciparum intraerythrocytic d.pdf}
}

@article{lingEffectSurfaceModification2024,
  title = {Effect of {{Surface Modification}} on the {{Luminescence}} of {{Individual Upconversion Nanoparticles}}},
  author = {Ling, Huan and Guan, Daoming and Wen, Rongrong and Hu, Jialing and Zhang, Yanxin and Zhao, Fei and Zhang, Yunxiang and Liu, Qian},
  year = {2024},
  journal = {Small},
  volume = {20},
  number = {26},
  pages = {2309035},
  issn = {1613-6829},
  doi = {10.1002/smll.202309035},
  urldate = {2024-08-24},
  abstract = {Lanthanide-doped upconversion nanoparticles (UCNPs) hold promise for single-molecule imaging owing to their excellent photostability and minimal autofluorescence. However, their limited water dispersibility, often from the hydrophobic oleic acid ligand during synthesis, is a challenge. To address this, various surface modification strategies' impact on single-particle upconversion luminescence are studied. UCNPs are made hydrophilic through methods like ligand exchange with dye IR806, HCl or NOBF4 treatment, silica coating (SiO2 or mesoporous mSiO2), and self-assembly with polymer of DSPE-PEG or F127. The studies revealed that UCNPs modified with NOBF4 and DSPE-PEG exhibited notably higher single-particle brightness with minimal quenching (3\% and 8\%, respectively), followed by SiO2, F127, IR806, mSiO2, and HCl (84\% quenching). HCl disrupted UCNPs's crystal lattice, weakening luminescence, while mSiO2 absorbed solvent molecules, causing luminescence quenching. Energy transfer to IR806 also reduced the brightness. Additionally, a prevalence of upconversion red emission over green is observed, with the red-to-green ratio increasing with irradiance. UCNPs coated with DSPE-PEG exhibited the brightest single-particle luminescence in water, retaining 48\% of its original emission due to a lower critical micelle concentration and superior water protection. In summary, the investigation provides valuable insights into the role of surface chemistry on UCNPs at the single-particle level.},
  copyright = {{\copyright} 2024 Wiley-VCH GmbH},
  langid = {english},
  lccn = {2},
  keywords = {monodispersity,resistance to water quenching,single-particle brightness,surface modification,UCNPs},
  annotation = {4 citations (Crossref/DOI) [2024-09-08]},
  file = {/Users/jerryling/Zotero/storage/DPLGMKWF/Ling et al. - 2024 - Effect of Surface Modification on the Luminescence.pdf;/Users/jerryling/Zotero/storage/T7HDIM8Z/smll.html}
}

@article{linQuantifyingOptimizingSingleMolecule2015,
  title = {Quantifying and {{Optimizing Single-Molecule Switching Nanoscopy}} at {{High Speeds}}},
  author = {Lin, Yu and Long, Jane J. and Huang, Fang and Duim, Whitney C. and Kirschbaum, Stefanie and Zhang, Yongdeng and Schroeder, Lena K. and Rebane, Aleksander A. and Velasco, Mary Grace M. and Virrueta, Alejandro and Moonan, Daniel W. and Jiao, Junyi and Hernandez, Sandy Y. and Zhang, Yongli and Bewersdorf, Joerg},
  year = {2015年5月26日},
  journal = {PLOS ONE},
  volume = {10},
  number = {5},
  pages = {e0128135},
  publisher = {Public Library of Science},
  issn = {1932-6203},
  doi = {10.1371/journal.pone.0128135},
  urldate = {2024-07-28},
  abstract = {Single-molecule switching nanoscopy overcomes the diffraction limit of light by stochastically switching single fluorescent molecules on and off, and then localizing their positions individually. Recent advances in this technique have greatly accelerated the data acquisition speed and improved the temporal resolution of super-resolution imaging. However, it has not been quantified whether this speed increase comes at the cost of compromised image quality. The spatial and temporal resolution depends on many factors, among which laser intensity and camera speed are the two most critical parameters. Here we quantitatively compare the image quality achieved when imaging Alexa Fluor 647-immunolabeled microtubules over an extended range of laser intensities and camera speeds using three criteria -- localization precision, density of localized molecules, and resolution of reconstructed images based on Fourier Ring Correlation. We found that, with optimized parameters, single-molecule switching nanoscopy at high speeds can achieve the same image quality as imaging at conventional speeds in a 5--25 times shorter time period. Furthermore, we measured the photoswitching kinetics of Alexa Fluor 647 from single-molecule experiments, and, based on this kinetic data, we developed algorithms to simulate single-molecule switching nanoscopy images. We used this software tool to demonstrate how laser intensity and camera speed affect the density of active fluorophores and influence the achievable resolution. Our study provides guidelines for choosing appropriate laser intensities for imaging Alexa Fluor 647 at different speeds and a quantification protocol for future evaluations of other probes and imaging parameters.},
  langid = {english},
  keywords = {Data acquisition,Fluorescence,Key,Technique},
  annotation = {65 citations (Crossref/DOI) [2024-09-08]},
  file = {/Users/jerryling/Zotero/storage/HKAGLX3B/Lin et al. - 2015 - Quantifying and Optimizing Single-Molecule Switchi.pdf}
}

