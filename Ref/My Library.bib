@article{liuUniversalInverseModeling2024,
  title = {Universal Inverse Modeling of Point Spread Functions for {{SMLM}} Localization and Microscope Characterization},
  author = {Liu, Sheng and Chen, Jianwei and Hellgoth, Jonas and M{\"u}ller, Lucas-Raphael and Ferdman, Boris and Karras, Christian and Xiao, Dafei and Lidke, Keith A. and Heintzmann, Rainer and Shechtman, Yoav and Li, Yiming and Ries, Jonas},
