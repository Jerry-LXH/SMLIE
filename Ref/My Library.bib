  author = {Park, Sanghyeon and Jo, Yonghyeon and Kang, Minsu and Hong, Jin Hee and Ko, Sangyoon and Kim, Suhyun and Park, Sangjun and Park, Hae Chul and Shim, Sang-Hee and Choi, Wonshik},
