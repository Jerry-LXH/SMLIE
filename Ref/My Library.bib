@article{wangDeepLearningAssistedSingleMoleculeTracking2021,
  title = {Deep-{{Learning-Assisted Single-Molecule Tracking}} on a {{Live Cell Membrane}}},
  author = {Wang, Qian and He, Hua and Zhang, Qian and Feng, Zhenzhen and Li, Jiqiang and Chen, Xiaoliang and Liu, Lihua and Wang, Xiaojuan and Ge, Baosheng and Yu, Daoyong and Ren, Hao and Huang, Fang},
  year = {2021},
