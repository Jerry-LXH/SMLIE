  author = {Glaser, Adam and Chandrashekar, Jayaram and Vasquez, Sonya and Arshadi, Cameron and Ouellette, Naveen and Jiang, Xiaoyun and Baka, Judith and Kovacs, Gabor and Woodard, Micah and Seshamani, Sharmishtaa and Cao, Kevin and Clack, Nathan and Recknagel, Andrew and Grim, Anna and Balaram, Pooja and Turschak, Emily and Hooper, Marcus and Liddell, Alan and Rohde, John and Hellevik, Ayana and Takasaki, Kevin and Barner, Lindsey Erion and Logsdon, Molly and Chronopoulos, Chris and de Vries, Saskia and Ting, Jonathan and Perlmutter, Steve and Kalmbach, Brian and Dembrow, Nikolai and Tasic, Bosiljka and Reid, R. Clay and Feng, David and Svoboda, Karel},
