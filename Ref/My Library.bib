@article{pastorNMRSpectroscopyCoordination2008,
  title = {{{NMR}} Spectroscopy in Coordination Supramolecular Chemistry: {{A}} Unique and Powerful Methodology},
  shorttitle = {{{NMR}} Spectroscopy in Coordination Supramolecular Chemistry},
  author = {Pastor, Aurelia and {Mart{\'i}nez-Viviente}, Elo{\'i}sa},
  year = {2008},
  month = nov,
  journal = {Coordination Chemistry Reviews},
